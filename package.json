{
  "name": "tokenboard",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "dev": "pnpm --filter @tokenboard/web dev",
    "build": "pnpm --filter @tokenboard/web build",
    "preview": "pnpm --filter @tokenboard/web preview",
    "deploy": "pnpm --filter @tokenboard/web run deploy",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "0.25.12",
      "miniflare>ws": "8.20.1",
      "minimatch@10.2.5>brace-expansion": "5.0.6"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
